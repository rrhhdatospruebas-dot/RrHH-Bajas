function titleDir(raw) {
  const d = (raw == null ? '' : String(raw)).trim();
  if (!d) return 'Sin dato';
  if (!/DIRECCI/i.test(d)) return 'Sin dato';
  const d2 = d.replace(/DIRECCION/g, 'DIRECCIÓN');
  const words = d2.toLowerCase().split(' ').filter(w => w.length);
  const out = words.map((w, i) => (i === 0 || w === 'de' || w === 'y') ? w : w.charAt(0).toUpperCase() + w.slice(1));
  let res = out.join(' ');
  if (res) res = res.charAt(0).toUpperCase() + res.slice(1);
  return res;
}
function formatGerencia(raw) {
  const s = (raw == null ? '' : String(raw)).trim();
  if (!s) return 'Sin dato';
  const lowered = s.charAt(0) + s.slice(1).toLowerCase();
  return lowered.replace(/gerencia/i, 'Gcia.');
}
function parseMotivo(raw) {
  if (MOTIVO_MAP[raw]) return MOTIVO_MAP[raw];
  if (/^Voluntary:/i.test(raw)) return ['V', raw];
  if (/^Involuntary:/i.test(raw)) return ['I', raw];
  return ['S', raw || 'Sin definir'];
}
function parseFecha(fechaRaw, mesTxt) {
  const mesKey = (mesTxt || '').trim().split(' ')[0].toLowerCase();
  const mesNum = MES_NUM_MAP[mesKey];
  let month, day, year;
  if (typeof fechaRaw === 'string' && fechaRaw.includes('/')) {
    const parts = fechaRaw.trim().split('/');
    day = parseInt(parts[0], 10); month = parseInt(parts[1], 10); year = parseInt(parts[2], 10);
  } else if (fechaRaw instanceof Date && !isNaN(fechaRaw)) {
    const m = fechaRaw.getUTCMonth() + 1, d = fechaRaw.getUTCDate(), y = fechaRaw.getUTCFullYear();
    if (mesNum && d === mesNum && m !== mesNum) { month = d; day = m; year = y; }
    else { month = m; day = d; year = y; }
  } else { return null; }
  if (mesNum && month !== mesNum) month = mesNum;
  if (!month || !day || !year) return null;
  return { month, day, year };
}
async function parseExcelFile(file) {
  const buf = await file.arrayBuffer();
  const wb = XLSX.read(buf, { type: 'array', cellDates: true });
  const sheetName = wb.SheetNames.find(n => n.trim().toUpperCase() === 'BAJAS');
  if (!sheetName) throw new Error('No se encontró una hoja llamada "BAJAS" en el archivo.');
  const ws = wb.Sheets[sheetName];
  const rows = XLSX.utils.sheet_to_json(ws, { header: 1, raw: true, defval: null });
  if (!rows.length) throw new Error('La hoja BAJAS está vacía.');
  const header = rows[0].map(h => (h == null ? '' : String(h)).trim());
  const col = name => header.findIndex(h => h.toLowerCase() === name.toLowerCase());
  const idx = {
    cod: col('Empleado (Cod)'), nombre: col('Empleado'), motivo: col('Motivo medida'),
    div: col('Div Personal'), fecha: col('Fecha Baja'), genero: col('Género'),
    mes: col('MES'), dir: col('DIRECCION'), ger: col('GERENCIA'), bp: col('BP')
  };
  for (const k of ['cod', 'nombre', 'motivo', 'div', 'fecha', 'genero', 'mes']) {
    if (idx[k] === -1) throw new Error(`Falta la columna requerida "${k}" en la hoja BAJAS.`);
  }
  const out = [];
  let skippedIdentity = 0, skippedFecha = 0, unclassifiedMotivo = 0;
  for (let r = 1; r < rows.length; r++) {
    const row = rows[r];
    if (!row) continue;
    const cod = row[idx.cod], nombre = row[idx.nombre];
    if ((cod == null || cod === '') && !nombre) continue;
    if (cod == null || cod === '' || !nombre) { skippedIdentity++; continue; }
    const motivoRaw = (row[idx.motivo] == null ? '' : String(row[idx.motivo])).trim();
    const mm = parseMotivo(motivoRaw);
    if (mm[0] === 'S') unclassifiedMotivo++;
    const divRaw = (row[idx.div] == null ? '' : String(row[idx.div])).trim();
    const site = SITE_MAP[divRaw] || divRaw;
    const mesTxt = (row[idx.mes] == null ? '' : String(row[idx.mes])).trim();
    const parsed = parseFecha(row[idx.fecha], mesTxt);
    if (!parsed) { skippedFecha++; continue; }
    const bp = (row[idx.bp] == null ? '' : String(row[idx.bp])).trim() || 'Sin dato';
    out.push({
      n: String(nombre),
      g: (row[idx.genero] == null ? '' : String(row[idx.genero])).trim() === 'Masculino' ? 'M' : 'F',
      t: mm[0],
      m: mm[1], s: site,
      f: `${parsed.year}-${String(parsed.month).padStart(2, '0')}-${String(parsed.day).padStart(2, '0')}`,
      mes: parsed.month, dir: titleDir(row[idx.dir]), ger: formatGerencia(row[idx.ger]), bp
    });
  }
  return { records: out, skippedIdentity, skippedFecha, unclassifiedMotivo };
}

function monthKeys(records) { return [...new Set(records.map(r => r.f.slice(0, 7)))].sort(); }
function monthYearLabel(records) {
  const keys = monthKeys(records);
  if (!keys.length) return 'Sin datos';
  const [y1, m1] = keys[0].split('-').map(Number);
  const [y2, m2] = keys[keys.length - 1].split('-').map(Number);
  if (y1 === y2) return m1 === m2 ? `${MES_NOM[m1]} ${y1}` : `${MES_NOM[m1]} a ${MES_NOM[m2]} ${y1}`;
  return `${MES_NOM[m1]} ${y1} a ${MES_NOM[m2]} ${y2}`;
}
function monthYearAbbrev(records) {
  const keys = monthKeys(records);
  if (!keys.length) return 'sin datos';
  const [y1, m1] = keys[0].split('-').map(Number);
  const [y2, m2] = keys[keys.length - 1].split('-').map(Number);
  const a1 = MES_ABR[m1].toLowerCase(), a2 = MES_ABR[m2].toLowerCase();
  if (y1 === y2) return m1 === m2 ? `${a1} ${y1}` : `${a1}–${a2} ${y1}`;
  return `${a1} ${y1}–${a2} ${y2}`;
}
function updateMeta() {
  PERIOD_LABEL = monthYearLabel(DATA);
  $('header-h1').textContent = `Bajas de personal — ${PERIOD_LABEL}`;
  const missingDir = DATA.filter(r => r.dir === 'Sin dato').length;
  const unclassified = DATA.filter(r => r.t === 'S').length;
  const abbrev = monthYearAbbrev(DATA);
  let txt = `Elaborado a partir de la planilla de bajas (${DATA.length} registro${DATA.length === 1 ? '' : 's'}, ${abbrev}).`;
  if (missingDir > 0) {
    txt += ` Nota de calidad de datos: ${missingDir} registro${missingDir === 1 ? '' : 's'} tiene${missingDir === 1 ? '' : 'n'} la columna DIRECCION vacía o mal cargada en la planilla y figura${missingDir === 1 ? '' : 'n'} como “Sin dato”.`;
  }
  if (unclassified > 0) txt += ` ${unclassified} baja${unclassified === 1 ? '' : 's'} queda${unclassified === 1 ? '' : 'n'} como “Sin definir” porque la planilla no indica el tipo.`;
  $('footer-text').textContent = txt;
}

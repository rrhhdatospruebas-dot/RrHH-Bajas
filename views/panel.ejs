/* reutiliza SITE_MAP y parseFecha ya definidos en la vista de Bajas */
async function parseAltasFile(file) {
  const buf = await file.arrayBuffer();
  const wb = XLSX.read(buf, { type: 'array', cellDates: true });
  const sheetName = wb.SheetNames.find(n => n.trim().toUpperCase() === 'ALTAS');
  if (!sheetName) throw new Error('No se encontró una hoja llamada "ALTAS" en el archivo.');
  const ws = wb.Sheets[sheetName];
  const rows = XLSX.utils.sheet_to_json(ws, { header: 1, raw: true, defval: null });
  if (!rows.length) throw new Error('La hoja ALTAS está vacía.');
  const header = rows[0].map(h => (h == null ? '' : String(h)).trim());
  const col = name => header.findIndex(h => h.toLowerCase() === name.toLowerCase());
  const idx = {
    cod: col('Empleado (Cod)'), nombre: col('Empleado'), fecha: col('Empleado (Ingreso)'),
    mes: col('Mes'), div: col('Div Personal'), genero: col('Género'), motivo: col('Motivo medida')
  };
  for (const k of ['cod', 'nombre', 'fecha', 'mes', 'div', 'genero']) {
    if (idx[k] === -1) throw new Error(`Falta la columna requerida "${k}" en la hoja ALTAS.`);
  }
  const out = [];
  let skippedFecha = 0;
  for (let r = 1; r < rows.length; r++) {
    const row = rows[r];
    if (!row) continue;
    const cod = row[idx.cod], nombre = row[idx.nombre];
    if (cod == null || cod === '' || !nombre) continue;
    const mesTxt = (row[idx.mes] == null ? '' : String(row[idx.mes])).trim();
    const parsed = parseFecha(row[idx.fecha], mesTxt);
    if (!parsed) { skippedFecha++; continue; }
    const divRaw = (row[idx.div] == null ? '' : String(row[idx.div])).trim();
    const site = SITE_MAP[divRaw] || divRaw || 'Sin dato';
    out.push({
      n: String(nombre),
      g: (row[idx.genero] == null ? '' : String(row[idx.genero])).trim() === 'Masculino' ? 'M' : 'F',
      mo: idx.motivo > -1 && row[idx.motivo] != null ? String(row[idx.motivo]).trim() : 'Sin dato',
      s: site,
      f: `${parsed.year}-${String(parsed.month).padStart(2, '0')}-${String(parsed.day).padStart(2, '0')}`,
      mes: parsed.month
    });
  }
  return { records: out, skippedFecha };
}

function altasMonthYearLabel(records) {
  /* Usa el campo "mes" (siempre referido a 2026) en vez de la fecha completa: algunos ingresos
     corresponden a colaboradores que ya estaban en la empresa y cambiaron de puesto este año,
     por lo que su fecha de ingreso original puede ser de años anteriores. */
  if (!records.length) return 'Sin datos';
  const meses = [...new Set(records.map(r => r.mes))].sort((a, b) => a - b);
  const m1 = meses[0], m2 = meses[meses.length - 1];
  return m1 === m2 ? `${MES_NOM[m1]} 2026` : `${MES_NOM[m1]} a ${MES_NOM[m2]} 2026`;
}
function altasUpdateMeta() {
  ALTAS_PERIOD_LABEL = altasMonthYearLabel(ALTAS_DATA);
  $('altas-h1').textContent = `Altas de personal — ${ALTAS_PERIOD_LABEL}`;
  $('altas-footer-text').textContent = `Elaborado a partir de la planilla de altas (${ALTAS_DATA.length} registro${ALTAS_DATA.length === 1 ? '' : 's'}). Algunos registros corresponden a colaboradores que ya estaban en la empresa y cambiaron de puesto durante 2026; su fecha de ingreso original puede ser de años anteriores.`;
}
function altasInitFiltersAndRender() {
  ALTAS_MESES = [...new Set(ALTAS_DATA.map(r => r.mes))].sort((a, b) => a - b);
  $('altas-f-mes').innerHTML = '<option value="">Todos</option>';
  ALTAS_MESES.forEach(m => $('altas-f-mes').insertAdjacentHTML('beforeend', `<option value="${m}">${MES_NOM[m]}</option>`));
  $('altas-f-sitio').innerHTML = '<option value="">Todos</option>';
  [...new Set(ALTAS_DATA.map(r => r.s))].sort((a, b) => a.localeCompare(b, 'es')).forEach(s =>
    $('altas-f-sitio').insertAdjacentHTML('beforeend', `<option value="${esc(s)}">${esc(s)}</option>`));
  altasState.mes = ''; altasState.sitio = ''; altasState.genero = ''; altasState.q = '';
  $('altas-f-mes').value = ''; $('altas-f-sitio').value = ''; $('altas-f-genero').value = ''; $('altas-q').value = '';
  altasRender();
}
['altas-f-mes', 'altas-f-sitio', 'altas-f-genero'].forEach(id => $(id).addEventListener('change', () => {
  altasState.mes = $('altas-f-mes').value; altasState.sitio = $('altas-f-sitio').value; altasState.genero = $('altas-f-genero').value;
  altasRender();
}));
$('altas-f-clear').addEventListener('click', () => {
  altasState.mes = altasState.sitio = altasState.genero = '';
  $('altas-f-mes').value = $('altas-f-sitio').value = $('altas-f-genero').value = '';
  altasRender();
});
$('altas-q').addEventListener('input', e => { altasState.q = e.target.value.trim().toLowerCase(); altasRenderTable(altasFiltered()); });

function altasFiltered() {
  return ALTAS_DATA.filter(r =>
    (!altasState.mes || r.mes === +altasState.mes) &&
    (!altasState.sitio || r.s === altasState.sitio) &&
    (!altasState.genero || r.g === altasState.genero));
}
/* filtro solo por mes+sitio (sin género), usado para el gráfico de diversidad y la comparación de género por planta */
function altasFilteredNoGenero() {
  return ALTAS_DATA.filter(r =>
    (!altasState.mes || r.mes === +altasState.mes) &&
    (!altasState.sitio || r.s === altasState.sitio));
}
/* filtro solo por sitio (ignora mes y género) — para reconstruir la serie mensual completa de un sitio */
function altasFilteredBySiteOnly(site) {
  return ALTAS_DATA.filter(r => !site || r.s === site);
}
/* bajas (usa el array DATA de la vista de Bajas, ya cargado en el mismo script) filtradas por sitio */
function bajasFilteredBySiteOnly(site) {
  return DATA.filter(r => !site || r.s === site);
}

function altasRenderKPIs(rows) {
  const total = rows.length;
  const f = rows.filter(r => r.g === 'F').length;
  const m = total - f;
  $('altas-k-total').textContent = total;
  $('altas-k-total-sub').textContent = total === ALTAS_DATA.length ? ALTAS_PERIOD_LABEL : `de ${ALTAS_DATA.length} en el período`;
  $('altas-k-f').textContent = f;
  $('altas-k-f-sub').textContent = pct(f, total) + ' del total';
  $('altas-k-m').textContent = m;
  $('altas-k-m-sub').textContent = pct(m, total) + ' del total';
  const porMes = countBy(rows, r => r.mes);
  let pico = null;
  porMes.forEach((n, mi) => { if (!pico || n > pico[1]) pico = [mi, n]; });
  $('altas-k-pico').textContent = pico ? MES_NOM[pico[0]] : '–';
  $('altas-k-pico-sub').textContent = pico ? `${pico[1]} altas` : '';
}
function altasRenderMes(rows) {
  const W = 680, H = 250, mL = 30, mR = 8, mT = 26, mB = 24;
  const iw = W - mL - mR, ih = H - mT - mB;
  const perMes = ALTAS_MESES.map(mi => {
    const m = rows.filter(r => r.mes === mi && r.g === 'M').length;
    const f = rows.filter(r => r.mes === mi && r.g === 'F').length;
    return { mi, m, f, tot: m + f };
  });
  const maxTot = Math.max(...perMes.map(d => d.tot), 1);
  const yMax = Math.max(5, Math.ceil(maxTot / 5) * 5);
  const y = val => mT + ih - (val / yMax) * ih;
  const step = iw / (ALTAS_MESES.length || 1);
  const bw = Math.min(52, step * 0.5);
  const GAP = 2;
  let s = `<svg viewBox="0 0 ${W} ${H}" role="img" aria-label="Altas por mes, apiladas por género">`;
  for (let t = 0; t <= yMax; t += 5) {
    s += `<line x1="${mL}" x2="${W - mR}" y1="${y(t)}" y2="${y(t)}" stroke="${t === 0 ? 'var(--baseline)' : 'var(--grid)'}" stroke-width="1"/>`;
    s += `<text x="${mL - 6}" y="${y(t) + 4}" text-anchor="end" font-size="11" fill="var(--muted)">${t}</text>`;
  }
  perMes.forEach((d, idx) => {
    const cx = mL + step * idx + step / 2;
    const x = cx - bw / 2;
    const hM = (d.m / yMax) * ih;
    const hF = (d.f / yMax) * ih;
    const yM = y(d.m);
    const r = 4;
    if (d.f > 0) {
      const yF = yM - GAP - hF;
      const hFc = Math.max(hF - 0, 1.5);
      s += roundedTop(x, yF, bw, hFc, r, 'var(--i)');
      if (d.m > 0) s += `<rect x="${x}" y="${yM}" width="${bw}" height="${Math.max(hM, 1.5)}" fill="var(--v)"/>`;
    } else if (d.m > 0) {
      s += roundedTop(x, yM, bw, Math.max(hM, 1.5), r, 'var(--v)');
    }
    if (d.tot > 0) s += `<text x="${cx}" y="${(d.f > 0 ? yM - GAP - hF : yM) - 6}" text-anchor="middle" font-size="12" fill="var(--ink-2)">${d.tot}</text>`;
    s += `<text x="${cx}" y="${H - 6}" text-anchor="middle" font-size="11.5" fill="var(--muted)">${MES_ABR[d.mi]}</text>`;
    s += `<rect x="${mL + step * idx}" y="${mT}" width="${step}" height="${ih}" fill="transparent" data-tip="${esc(`<b>${MES_NOM[d.mi]}</b> — ${d.tot} alta${d.tot === 1 ? '' : 's'}<br>Masculino: <b>${d.m}</b> · Femenino: <b>${d.f}</b>`)}"/>`;
  });
  s += '</svg>';
  $('altas-c-mes').innerHTML = s;
}
function altasRenderSitio(rows) {
  const items = [...countBy(rows, r => r.s).entries()]
    .map(([label, n]) => ({ label, n, total: rows.length, color: 'var(--v)' }))
    .sort((a, b) => b.n - a.n);
  renderBajasHBars($('altas-c-sitio'), items, 'del total filtrado');
}
function altasRenderGeneroPorSitio(rows) {
  const m = new Map();
  rows.forEach(r => {
    const cur = m.get(r.s) || { f: 0, m: 0 };
    if (r.g === 'F') cur.f++; else cur.m++;
    m.set(r.s, cur);
  });
  const items = [...m.entries()].map(([label, v]) => ({ label, f: v.f, m: v.m, total: v.f + v.m }))
    .sort((a, b) => b.total - a.total);
  const max = Math.max(...items.map(d => d.total), 1);
  $('altas-c-genero-sitio').innerHTML = items.map(d => {
    const wF = (d.f / max * 100).toFixed(1), wM = (d.m / max * 100).toFixed(1);
    return `
    <div class="hrow" data-tip="${esc(`<b>${d.label}</b><br>Femenino: <b>${d.f}</b> · Masculino: <b>${d.m}</b> · Total: <b>${d.total}</b>`)}">
      <span class="hl" title="${esc(d.label)}">${esc(d.label)}</span>
      <span class="track"><span class="bar" style="width:${wF}%; left:0; background:var(--i)"></span><span class="bar" style="width:${wM}%; left:${wF}%; background:var(--v)"></span></span>
      <span class="hv">${d.total}</span>
    </div>`;
  }).join('');
}
function altasDiversidadSerie(site) {
  /* Serie mensual de % mujeres para un sitio (o compañía completa si site es '' ), usando la
     dotación real cerrada de cada mes (nómina al 31/1 y pivots reales de nómina feb-jun) — ya no
     es una estimación por altas menos bajas, es el headcount real de cada cierre mensual. */
  const meses = ALTAS_MESES.length ? ALTAS_MESES : [1];
  return meses.map(mi => {
    const d = altasNominaFor(mi, site);
    return { mi, f: d.f, tot: d.tot, pctF: d.tot ? (d.f / d.tot * 100) : null };
  });
}
function altasRenderDiversidad() {
  /* Small multiples: un mini-gráfico por planta en vez de todas las líneas superpuestas — mismo dato
     (base nómina enero + altas acumuladas), mucho más fácil de leer de un vistazo. */
  const sites = Object.keys(NOMINA_ENERO_MAP).sort((a, b) => NOMINA_ENERO_MAP[b].tot - NOMINA_ENERO_MAP[a].tot);
  const total = altasDiversidadSerie('');
  const entries = [{ label: 'Total compañía', pts: total, isTotal: true }, ...sites.map(site => ({ label: site, pts: altasDiversidadSerie(site), isTotal: false }))];

  function miniCard({ label, pts, isTotal }) {
    const W = 150, H = 46, pad = 4;
    const first = pts.find(p => p.pctF != null);
    const last = [...pts].reverse().find(p => p.pctF != null);
    const cur = last ? Math.round(last.pctF) : null;
    const ene = first ? Math.round(first.pctF) : null;
    const delta = (cur != null && ene != null) ? cur - ene : null;
    const trendColor = delta == null ? 'var(--muted)' : (delta >= 0 ? 'var(--i)' : 'var(--neg)');
    const yMax = 100;
    const y = v => pad + (H - 2 * pad) - (v / yMax) * (H - 2 * pad);
    const step = (W - 2 * pad) / (pts.length - 1 || 1);
    const px = idx => pad + step * idx;
    let d = '';
    pts.forEach((pt, idx) => { if (pt.pctF != null) { d += `${d === '' ? 'M' : 'L'}${px(idx)},${y(pt.pctF)} `; } });
    let dots = '';
    pts.forEach((pt, idx) => {
      if (pt.pctF == null) return;
      dots += `<circle cx="${px(idx)}" cy="${y(pt.pctF)}" r="2" fill="${trendColor}" data-tip="${esc(`<b>${label}</b> — ${MES_NOM[pt.mi]}<br>% mujeres: <b>${Math.round(pt.pctF)}%</b> (${pt.f} de ${pt.tot})`)}"/>`;
    });
    const svg = `<svg viewBox="0 0 ${W} ${H}" width="100%" height="${H}" preserveAspectRatio="none" role="img" aria-label="Trayectoria de % mujeres — ${esc(label)}">
      <line x1="${pad}" x2="${W - pad}" y1="${y(50)}" y2="${y(50)}" stroke="var(--grid)" stroke-width="1" stroke-dasharray="2 2"/>
      <path d="${d}" fill="none" stroke="${trendColor}" stroke-width="1.8"/>
      ${dots}
    </svg>`;
    const deltaTxt = delta == null ? '' : `<span style="color:${delta >= 0 ? 'var(--i)' : 'var(--neg)'};">${delta > 0 ? '+' : ''}${delta} p.p. vs. ene.</span>`;
    return `<div style="border:1px solid var(--border); border-radius:8px; padding:8px 10px; background:var(--surface); ${isTotal ? 'border-color:var(--ink);' : ''}">
      <div style="display:flex; justify-content:space-between; align-items:baseline; gap:6px;">
        <span style="font-size:11.5px; font-weight:${isTotal ? 700 : 600}; color:var(--ink); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="${esc(label)}">${esc(label)}</span>
        <span style="font-size:13px; font-weight:700; color:var(--ink);">${cur != null ? cur + '%' : '–'}</span>
      </div>
      ${svg}
      <div style="font-size:10.5px; color:var(--muted); margin-top:2px;">${deltaTxt}</div>
    </div>`;
  }

  $('altas-c-diversidad').innerHTML =
    `<div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(150px, 1fr)); gap:10px;">${entries.map(miniCard).join('')}</div>`;
  $('altas-div-legend').innerHTML =
    `<span>Cada mini-gráfico va de 0% a 100%; la línea punteada marca el 50%. Color verde = subió respecto a enero, rojo = bajó.</span>`;
}
function altasRenderDiversidadTabla() {
  const lastMi = ALTAS_MESES.length ? ALTAS_MESES[ALTAS_MESES.length - 1] : 1;
  const hastaMi = altasState.mes ? +altasState.mes : lastMi;
  ['altas-div-mes-lbl', 'altas-div-mes-lbl2', 'altas-div-mes-lbl3', 'altas-div-mes-lbl4'].forEach(id => { $(id).textContent = MES_ABR[hastaMi]; });
  const sites = Object.keys(NOMINA_ENERO_MAP).sort((a, b) => a.localeCompare(b, 'es'));
  const rowsHtml = sites.map(site => {
    const base = NOMINA_ENERO_MAP[site];
    const pctEne = base.tot ? (base.f / base.tot * 100) : null;
    const rowsSite = altasFilteredBySiteOnly(site).filter(r => r.mes > 1 && r.mes <= hastaMi);
    const bajasSite = bajasFilteredBySiteOnly(site).filter(r => r.mes > 1 && r.mes <= hastaMi);
    const altasF = rowsSite.filter(r => r.g === 'F').length;
    const altasM = rowsSite.filter(r => r.g === 'M').length;
    const bajasF = bajasSite.filter(r => r.g === 'F').length;
    const bajasM = bajasSite.filter(r => r.g === 'M').length;
    /* dotación y % actual: nómina real del mes seleccionado (no una estimación por altas-bajas) */
    const cur = altasNominaFor(hastaMi, site);
    const pctCur = cur.tot ? (cur.f / cur.tot * 100) : null;
    const delta = (pctEne != null && pctCur != null) ? (pctCur - pctEne) : null;
    return `<tr>
      <td>${esc(site)}</td>
      <td class="num">${base.tot}</td>
      <td class="num">${pctEne != null ? Math.round(pctEne) + '%' : '–'}</td>
      <td class="num">${altasF}</td>
      <td class="num">${altasM}</td>
      <td class="num">${bajasF}</td>
      <td class="num">${bajasM}</td>
      <td class="num">${cur.tot}</td>
      <td class="num">${pctCur != null ? Math.round(pctCur) + '%' : '–'}</td>
      <td class="num">${delta != null ? `<span class="pill ${delta >= 0 ? 'pos' : 'neg'}">${delta > 0 ? '+' : ''}${delta.toFixed(1)}</span>` : '–'}</td>
    </tr>`;
  }).join('');
  $('altas-div-tbody').innerHTML = rowsHtml;
}
function altasRenderTable(rows) {
  const q = altasState.q;
  const list = rows
    .filter(r => !q || [r.n, r.s].join(' ').toLowerCase().includes(q))
    .sort((a, b) => a.f.localeCompare(b.f));
  $('altas-tbody').innerHTML = list.map(r => {
    const [y, mo, d] = r.f.split('-');
    return `<tr>
      <td>${esc(r.n)}</td><td class="num">${d}/${mo}/${y}</td>
      <td><span class="pill ${r.g === 'F' ? 'I' : 'V'}">${r.g === 'F' ? 'Femenino' : 'Masculino'}</span></td>
      <td>${esc(r.mo)}</td><td>${esc(r.s)}</td>
    </tr>`;
  }).join('');
  $('altas-tempty').hidden = list.length > 0;
  $('altas-tcount').textContent = `${list.length} de ${ALTAS_DATA.length} registros`;
}
function altasRender() {
  const rows = altasFiltered();
  const rowsNoGenero = altasFilteredNoGenero();
  $('altas-f-clear').classList.toggle('on', !!(altasState.mes || altasState.sitio || altasState.genero));
  altasRenderKPIs(rows);
  altasRenderMes(rows);
  altasRenderSitio(rows);
  altasRenderGeneroPorSitio(rowsNoGenero);
  altasRenderDiversidad();
  altasRenderDiversidadTabla();
  altasRenderTable(rows);
}
async function altasInit() {
  try {
    const stored = await window.storage.get('altas-dataset', true);
    if (stored && stored.value) {
      const parsed = JSON.parse(stored.value);
      if (parsed && Array.isArray(parsed.records) && parsed.records.length) {
        ALTAS_DATA = parsed.records;
        const fecha = parsed.uploadedAt ? new Date(parsed.uploadedAt).toLocaleString('es-AR') : '';
        $('altas-upload-status').textContent = `Últimos datos cargados: "${parsed.filename || 'archivo'}"${fecha ? ' · ' + fecha : ''}`;
        $('altas-upload-status').className = 'upload-status ok';
      }
    }
  } catch (err) {}
  altasInitFiltersAndRender();
  altasUpdateMeta();
}
onChange('altas-file-input', async (e) => {
  const file = e.target.files[0];
  if (!file) return;
  const statusEl = $('altas-upload-status');
  statusEl.textContent = 'Procesando archivo…'; statusEl.className = 'upload-status';
  try {
    const { records, skippedFecha } = await parseAltasFile(file);
    if (!records.length) throw new Error('No se encontraron registros válidos en la hoja ALTAS.');
    ALTAS_DATA = records;
    const uploadedAt = new Date().toISOString();
    try { await window.storage.set('altas-dataset', JSON.stringify({ records, uploadedAt, filename: file.name }), true); }
    catch (err) { throw new Error(`El archivo se procesó pero NO se guardó en el servidor (${err.message}). Los demás usuarios no van a ver este cambio: probá de nuevo.`); }
    altasInitFiltersAndRender(); altasUpdateMeta();
    let msg = `✓ ${records.length} registros cargados desde "${file.name}".`;
    if (skippedFecha) msg += ` ${skippedFecha} fila(s) con fecha inválida omitida(s).`;
    statusEl.textContent = msg; statusEl.className = 'upload-status ok';
  } catch (err) { statusEl.textContent = '⚠ ' + err.message; statusEl.className = 'upload-status err'; }
  e.target.value = '';
});

/* ----- tabs ----- */
function showTab(tab) {
  $('view-bajas').hidden = tab !== 'bajas';
  $('view-mtp').hidden = tab !== 'mtp';
  $('view-altas').hidden = tab !== 'altas';
  $('tab-btn-bajas').classList.toggle('active', tab === 'bajas');
  $('tab-btn-mtp').classList.toggle('active', tab === 'mtp');
  $('tab-btn-altas').classList.toggle('active', tab === 'altas');
  $('tab-btn-bajas').setAttribute('aria-selected', tab === 'bajas');
  $('tab-btn-mtp').setAttribute('aria-selected', tab === 'mtp');
  $('tab-btn-altas').setAttribute('aria-selected', tab === 'altas');
}
$('tab-btn-bajas').addEventListener('click', () => showTab('bajas'));
$('tab-btn-mtp').addEventListener('click', () => showTab('mtp'));
$('tab-btn-altas').addEventListener('click', () => showTab('altas'));

init();
mtpInit();
altasInit();
</script>
</body>
</html>

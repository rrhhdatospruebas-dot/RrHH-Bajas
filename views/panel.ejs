function filtered() {
  return DATA.filter(r =>
    (!state.mes || r.mes === +state.mes) &&
    (!state.tipo || r.t === state.tipo) &&
    (!state.sitio || r.s === state.sitio));
}
function renderKPIs(rows) {
  const total = rows.length;
  const v = rows.filter(r => r.t === 'V').length;
  const i = rows.filter(r => r.t === 'I').length;
  const s = total - v - i;
  $('k-total').textContent = total;
  $('k-total-sub').textContent = (total === DATA.length ? PERIOD_LABEL : `de ${DATA.length} en el período`) + (s ? ` · ${s} sin definir` : '');
  $('k-vol').textContent = v;
  $('k-vol-sub').textContent = pct(v, total) + ' del total';
  $('k-inv').textContent = i;
  $('k-inv-sub').textContent = pct(i, total) + ' del total';
  const porMes = countBy(rows, r => r.mes);
  let pico = null;
  porMes.forEach((n, m) => { if (!pico || n > pico[1]) pico = [m, n]; });
  $('k-pico').textContent = pico ? MES_NOM[pico[0]] : '–';
  $('k-pico-sub').textContent = pico ? `${pico[1]} bajas` : '';
}
function renderMes(rows) {
  const W = 680, H = 250, mL = 30, mR = 8, mT = 26, mB = 24;
  const iw = W - mL - mR, ih = H - mT - mB;
  const perMes = MESES.map(m => {
    const v = rows.filter(r => r.mes === m && r.t === 'V').length;
    const i = rows.filter(r => r.mes === m && r.t === 'I').length;
    const s = rows.filter(r => r.mes === m && r.t === 'S').length;
    return { m, v, i, s, tot: v + i + s };
  });
  const maxTot = Math.max(...perMes.map(d => d.tot), 1);
  const yMax = Math.max(5, Math.ceil(maxTot / 5) * 5);
  const y = val => mT + ih - (val / yMax) * ih;
  const step = iw / MESES.length;
  const bw = Math.min(52, step * 0.5);
  const GAP = 2;
  let s = `<svg viewBox="0 0 ${W} ${H}" role="img" aria-label="Bajas por mes, apiladas por tipo">`;
  for (let t = 0; t <= yMax; t += 5) {
    s += `<line x1="${mL}" x2="${W - mR}" y1="${y(t)}" y2="${y(t)}" stroke="${t === 0 ? 'var(--baseline)' : 'var(--grid)'}" stroke-width="1"/>`;
    s += `<text x="${mL - 6}" y="${y(t) + 4}" text-anchor="end" font-size="11" fill="var(--muted)">${t}</text>`;
  }
  perMes.forEach((d, idx) => {
    const cx = mL + step * idx + step / 2;
    const x = cx - bw / 2;
    const r = 4;
    const segments = [
      { n: d.v, color: 'var(--v)' },
      { n: d.i, color: 'var(--i)' },
      { n: d.s, color: 'var(--muted)' },
    ].filter(segment => segment.n > 0);
    let top = mT + ih;
    segments.forEach((segment, segmentIndex) => {
      const h = Math.max((segment.n / yMax) * ih, 1.5);
      top -= h;
      if (segmentIndex === segments.length - 1) s += roundedTop(x, top, bw, h, r, segment.color);
      else s += `<rect x="${x}" y="${top}" width="${bw}" height="${h}" fill="${segment.color}"/>`;
      if (segmentIndex < segments.length - 1) top -= GAP;
    });
    if (d.tot > 0) s += `<text x="${cx}" y="${top - 6}" text-anchor="middle" font-size="12" fill="var(--ink-2)">${d.tot}</text>`;
    s += `<text x="${cx}" y="${H - 6}" text-anchor="middle" font-size="11.5" fill="var(--muted)">${MES_ABR[d.m]}</text>`;
    s += `<rect x="${mL + step * idx}" y="${mT}" width="${step}" height="${ih}" fill="transparent" class="hovcol" data-tip="${esc(`<b>${MES_NOM[d.m]}</b> — ${d.tot} baja${d.tot === 1 ? '' : 's'}<br>Voluntarias: <b>${d.v}</b> · Involuntarias: <b>${d.i}</b> · Sin definir: <b>${d.s}</b>`)}"/>`;
  });
  s += '</svg>';
  $('c-mes').innerHTML = s;
}
function roundedTop(x, yy, w, h, r, fill) {
  r = Math.min(r, h, w / 2);
  return `<path d="M${x},${yy + h} L${x},${yy + r} Q${x},${yy} ${x + r},${yy} L${x + w - r},${yy} Q${x + w},${yy} ${x + w},${yy + r} L${x + w},${yy + h} Z" fill="${fill}"/>`;
}
function renderBajasHBars(el, items, tipLabel) {
  const max = Math.max(...items.map(d => d.n), 1);
  el.innerHTML = items.map(d => `
    <div class="hrow" data-tip="${esc(`<b>${d.label}</b><br>${d.n} baja${d.n === 1 ? '' : 's'} · ${pct(d.n, d.total)} ${tipLabel}`)}">
      <span class="hl" title="${esc(d.label)}">${esc(d.label)}</span>
      <span class="track" style="background:transparent"><span class="bar" style="width:${(d.n / max * 100).toFixed(1)}%; left:0; background:${d.color}"></span></span>
      <span class="hv">${d.n}</span>
    </div>`).join('');
}
function renderMotivo(rows) {
  const m = new Map();
  rows.forEach(r => { const k = r.m + '|' + r.t; m.set(k, (m.get(k) || 0) + 1); });
  const items = [...m.entries()].map(([k, n]) => {
    const [label, t] = k.split('|');
    return { label: label + (label === 'Fin de contrato' ? (t === 'V' ? ' (vol.)' : ' (invol.)') : ''), n, total: rows.length, color: t === 'V' ? 'var(--v)' : t === 'I' ? 'var(--i)' : 'var(--muted)' };
  }).sort((a, b) => b.n - a.n);
  renderBajasHBars($('c-motivo'), items, 'del total filtrado');
}
function renderDim(el, rows, key) {
  const items = [...countBy(rows, key).entries()]
    .map(([label, n]) => ({ label, n, total: rows.length, color: 'var(--v)' }))
    .sort((a, b) => b.n - a.n);
  renderBajasHBars(el, items, 'del total filtrado');
}
function renderGenero(rows) {
  const m = rows.filter(r => r.g === 'M').length;
  const f = rows.length - m;
  const bar = $('c-gen-bar'), leg = $('c-gen-leg');
  if (!rows.length) { bar.innerHTML = ''; leg.innerHTML = '<span class="row">Sin datos para los filtros actuales.</span>'; return; }
  bar.innerHTML =
    (m ? `<div style="flex:${m}; background:var(--v)" data-tip="<b>Masculino</b>: ${m} (${pct(m, rows.length)})"></div>` : '') +
    (f ? `<div style="flex:${f}; background:var(--i)" data-tip="<b>Femenino</b>: ${f} (${pct(f, rows.length)})"></div>` : '');
  leg.innerHTML = `
    <span class="row" style="display:flex;align-items:center;gap:8px;"><span class="sw v"></span>Masculino&nbsp;<b>${m}</b>&nbsp;· ${pct(m, rows.length)}</span>
    <span class="row" style="display:flex;align-items:center;gap:8px;"><span class="sw i"></span>Femenino&nbsp;<b>${f}</b>&nbsp;· ${pct(f, rows.length)}</span>`;
}
function renderTable(rows) {
  const q = state.q;
  const list = rows
    .filter(r => !q || [r.n, r.s, r.dir, r.ger, r.bp, r.m].join(' ').toLowerCase().includes(q))
    .sort((a, b) => a.f.localeCompare(b.f));
  $('tbody').innerHTML = list.map(r => {
    const [y, mo, d] = r.f.split('-');
    return `<tr>
      <td>${esc(r.n)}</td><td class="num">${d}/${mo}/${y}</td>
      <td><span class="pill ${r.t}">${TIPO_LABEL[r.t] || 'Sin definir'}</span></td>
      <td>${esc(r.m)}</td><td>${esc(r.s)}</td><td>${esc(r.dir)}</td><td>${esc(r.ger)}</td><td>${esc(r.bp)}</td>
    </tr>`;
  }).join('');
  $('tempty').hidden = list.length > 0;
  $('tcount').textContent = `${list.length} de ${DATA.length} registros`;
}
function render() {
  const rows = filtered();
  $('f-clear').classList.toggle('on', !!(state.mes || state.tipo || state.sitio));
  renderKPIs(rows);
  renderMes(rows);
  renderMotivo(rows);
  renderDim($('c-sitio'), rows, r => r.s);
  renderDim($('c-dir'), rows, r => r.dir);
  renderGenero(rows);
  renderTable(rows);
}
async function init() {
  try {
    const stored = await window.storage.get('bajas-dataset', true);
    if (stored && stored.value) {
      const parsed = JSON.parse(stored.value);
      if (parsed && Array.isArray(parsed.records) && parsed.records.length) {
        DATA = parsed.records;
        const fecha = parsed.uploadedAt ? new Date(parsed.uploadedAt).toLocaleString('es-AR') : '';
        $('upload-status').textContent = `Últimos datos cargados: "${parsed.filename || 'archivo'}"${fecha ? ' · ' + fecha : ''}`;
        $('upload-status').className = 'upload-status ok';
      }
    }
  } catch (err) {}
  initFiltersAndRender();
  updateMeta();
}
onChange('file-input', async (e) => {
  const file = e.target.files[0];
  if (!file) return;
  const statusEl = $('upload-status');
  statusEl.textContent = 'Procesando archivo…'; statusEl.className = 'upload-status';
  try {
    const { records, skippedIdentity, skippedFecha, unclassifiedMotivo } = await parseExcelFile(file);
    if (!records.length) throw new Error('No se encontraron registros válidos en la hoja BAJAS.');
    if (skippedIdentity || skippedFecha) {
      throw new Error(`No se actualizó el panel: ${skippedIdentity + skippedFecha} fila(s) incompleta(s) (${skippedIdentity} sin empleado/código y ${skippedFecha} con fecha inválida). Corregí esas filas y volvé a cargar el archivo.`);
    }
    DATA = records;
    const uploadedAt = new Date().toISOString();
    try { await window.storage.set('bajas-dataset', JSON.stringify({ records, uploadedAt, filename: file.name }), true); }
    catch (err) { throw new Error(`El archivo se procesó pero NO se guardó en el servidor (${err.message}). Los demás usuarios no van a ver este cambio: probá de nuevo.`); }
    initFiltersAndRender(); updateMeta();
    let msg = `✓ ${records.length} registros cargados desde "${file.name}".`;
    if (unclassifiedMotivo) msg += ` ${unclassifiedMotivo} fila(s) incluida(s) como “Sin definir”.`;
    statusEl.textContent = msg; statusEl.className = 'upload-status ok';
  } catch (err) { statusEl.textContent = '⚠ ' + err.message; statusEl.className = 'upload-status err'; }
  e.target.value = '';
});

/* ================================================================ */
/* VISTA: COMPARACIÓN HEADCOUNT VS MTP                               */
/* ================================================================ */
const MTP_MES_NOM = ['Enero','Febrero','Marzo','Abril','Mayo','Junio'];
const MTP_MES_ABR = ['Ene','Feb','Mar','Abr','May','Jun'];
const MTP_PLANT_LABELS = {
  'CAPDEVILLE': 'Pta. Capdeville', 'CAMPANA': 'Pta. Campana', 'MALAGUEÑO': 'Pta. Malagueño',
  'PUESTO VIEJO': 'Pta. Puesto Viejo', 'AÑACUA': 'Añacua', 'RMX': 'RMX',
  'CORPO': 'Corpo', 'AGREGADOS': 'Agregados', 'GEOCYCLE': 'Geocycle',
};

const MTP_DATA_DEFAULT = [{"planta":"Pta. Capdeville","baseline":148,"real":[174,175,175,173,177,178],"mtp":[174,175,175,173,177,178],"blueprint":153},{"planta":"Pta. Campana","baseline":90,"real":[100,101,100,96,99,99],"mtp":[100,101,100,96,99,99],"blueprint":92},{"planta":"Pta. Malagueño","baseline":222,"real":[269,270,269,268,264,262],"mtp":[269,270,269,268,264,264],"blueprint":159},{"planta":"Pta. Puesto Viejo","baseline":139,"real":[189,189,187,186,182,180],"mtp":[189,189,187,186,182,182],"blueprint":143},{"planta":"Añacua","baseline":8,"real":[13,12,13,12,15,17],"mtp":[13,12,13,12,15,18],"blueprint":null},{"planta":"RMX","baseline":49,"real":[52,55,56,57,60,59],"mtp":[52,55,56,57,60,60],"blueprint":null},{"planta":"Corpo","baseline":200,"real":[156,154,153,151,153,155],"mtp":[156,154,153,151,153,153],"blueprint":null},{"planta":"Agregados","baseline":25,"real":[25,24,24,24,24,25],"mtp":[25,24,24,24,24,26],"blueprint":null},{"planta":"Geocycle","baseline":56,"real":[55,55,54,54,54,53],"mtp":[55,55,54,54,54,54],"blueprint":null}];
let MTP_DATA = MTP_DATA_DEFAULT.slice();
const mtpState = { mes: 5, q: '' };

/* Objetivo del bloque general = MTP siempre (todas las plantas), sin usar Blueprint. */
function mtpObjetivo(p, mi) { return p.mtp[mi] || 0; }
function mtpTotalsFor(mi) {
  let real = 0, objetivo = 0, baseline = 0;
  MTP_DATA.forEach(p => { real += p.real[mi] || 0; objetivo += mtpObjetivo(p, mi); baseline += p.baseline || 0; });
  return { real, objetivo, baseline, gap: real - objetivo, gapBase: real - baseline };
}
function mtpRenderKPIs() {
  const mi = mtpState.mes;
  const { real, objetivo, baseline, gap, gapBase } = mtpTotalsFor(mi);
  $('mtp-k-real').textContent = real;
  $('mtp-k-real-sub').textContent = MTP_MES_NOM[mi] + ' 2026';
  const baseEl = $('mtp-k-base');
  baseEl.textContent = (gapBase > 0 ? '+' : '') + gapBase;
  baseEl.className = 'val ' + (gapBase >= 0 ? 'pos' : 'neg');
  $('mtp-k-base-sub').textContent = `vs. ${baseline} al 31/12/25`;
  const gapEl = $('mtp-k-gap');
  gapEl.textContent = (gap > 0 ? '+' : '') + gap;
  gapEl.className = 'val ' + (gap >= 0 ? 'pos' : 'neg');
  $('mtp-k-gap-sub').textContent = gap >= 0 ? 'headcount por encima del MTP' : 'headcount por debajo del MTP';
  const pctEl = $('mtp-k-pct');
  const cumplimiento = objetivo ? Math.round(real / objetivo * 100) : 0;
  pctEl.textContent = cumplimiento + '%';
  pctEl.className = 'val ' + (cumplimiento >= 100 ? 'pos' : (cumplimiento >= 97 ? '' : 'neg'));
  $('mtp-k-pct-sub').textContent = 'Real / MTP — todas las plantas';
}
function mtpRenderTrend() {
  const W = 680, H = 250, mL = 34, mR = 8, mT = 20, mB = 24;
  const iw = W - mL - mR, ih = H - mT - mB;
  const perMes = [0, 1, 2, 3, 4, 5].map(mi => mtpTotalsFor(mi));
  const maxV = Math.max(...perMes.map(d => Math.max(d.real, d.objetivo, d.baseline)), 1);
  const yMax = Math.ceil(maxV / 50) * 50 || 50;
  const y = v => mT + ih - (v / yMax) * ih;
  const step = iw / 6;
  const px = idx => mL + step * idx + step / 2;
  let s = `<svg viewBox="0 0 ${W} ${H}" role="img" aria-label="Evolución Real vs MTP vs Línea base por mes">`;
  for (let t = 0; t <= yMax; t += Math.ceil(yMax / 4 / 50) * 50 || 50) {
    s += `<line x1="${mL}" x2="${W - mR}" y1="${y(t)}" y2="${y(t)}" stroke="${t === 0 ? 'var(--baseline)' : 'var(--grid)'}" stroke-width="1"/>`;
    s += `<text x="${mL - 6}" y="${y(t) + 4}" text-anchor="end" font-size="11" fill="var(--muted)">${t}</text>`;
  }
  function pathFor(key) {
    let d = '';
    perMes.forEach((pt, idx) => { d += `${d === '' ? 'M' : 'L'}${px(idx)},${y(pt[key])} `; });
    return d;
  }
  /* Línea base (31/12/25) — constante, se dibuja primero y punteada para no tapar a las otras */
  s += `<path d="${pathFor('baseline')}" fill="none" stroke="var(--muted)" stroke-width="1.75" stroke-dasharray="6 4"/>`;
  /* MTP — punteado más corto para distinguirla cuando coincide con el Real */
  s += `<path d="${pathFor('objetivo')}" fill="none" stroke="var(--v)" stroke-width="3" stroke-dasharray="1 4" stroke-linecap="round"/>`;
  /* Real — sólida, encima de todo */
  s += `<path d="${pathFor('real')}" fill="none" stroke="var(--i)" stroke-width="2"/>`;
  perMes.forEach((pt, idx) => {
    s += `<circle cx="${px(idx)}" cy="${y(pt.baseline)}" r="2.5" fill="var(--muted)"/>`;
    s += `<circle cx="${px(idx)}" cy="${y(pt.objetivo)}" r="3" fill="var(--v)"/>`;
    s += `<circle cx="${px(idx)}" cy="${y(pt.real)}" r="3" fill="var(--i)"/>`;
    s += `<text x="${px(idx)}" y="${H - 6}" text-anchor="middle" font-size="11.5" fill="var(--muted)">${MTP_MES_ABR[idx]}</text>`;
    s += `<rect x="${mL + step * idx}" y="${mT}" width="${step}" height="${ih}" fill="transparent" data-tip="${esc(`<b>${MTP_MES_NOM[idx]}</b><br>Real: <b>${pt.real}</b> · MTP: <b>${pt.objetivo}</b> · Línea base: <b>${pt.baseline}</b>`)}"/>`;
  });
  s += '</svg>';
  $('mtp-c-trend').innerHTML = s;
}
function mtpRenderBlueprint() {
  const mi = mtpState.mes;
  const plants = MTP_DATA.filter(p => p.blueprint != null);
  const W = 680, H = 260, mL = 34, mR = 8, mT = 24, mB = 30;
  const iw = W - mL - mR, ih = H - mT - mB;
  const maxV = Math.max(...plants.flatMap(p => [p.real[mi] || 0, p.blueprint, p.mtp[mi] || 0]), 1);
  const yMax = Math.ceil(maxV / 20) * 20 || 20;
  const y = v => mT + ih - (v / yMax) * ih;
  const step = iw / (plants.length || 1);
  const groupW = Math.min(140, step * 0.72);
  const barW = groupW / 3 - 3;
  let s = `<svg viewBox="0 0 ${W} ${H}" role="img" aria-label="Matriz de brecha Blueprint">`;
  for (let t = 0; t <= yMax; t += Math.ceil(yMax / 4 / 20) * 20 || 20) {
    s += `<line x1="${mL}" x2="${W - mR}" y1="${y(t)}" y2="${y(t)}" stroke="${t === 0 ? 'var(--baseline)' : 'var(--grid)'}" stroke-width="1"/>`;
    s += `<text x="${mL - 6}" y="${y(t) + 4}" text-anchor="end" font-size="11" fill="var(--muted)">${t}</text>`;
  }
  plants.forEach((p, idx) => {
    const cx = mL + step * idx + step / 2;
    const gx = cx - groupW / 2;
    const real = p.real[mi] || 0, bp = p.blueprint, m = p.mtp[mi] || 0;
    const tip = esc(`<b>${p.planta}</b><br>Real: <b>${real}</b><br>Blueprint: <b>${bp}</b> (dif: <b>${real - bp > 0 ? '+' : ''}${real - bp}</b>)<br>MTP: <b>${m}</b>`);
    [['real', real, 'var(--i)'], ['blueprint', bp, '#c0392b'], ['mtp', m, 'var(--v)']].forEach(([k, val, color], bi) => {
      const bx = gx + bi * (barW + 3);
      const bh = (val / yMax) * ih;
      s += `<rect x="${bx}" y="${y(val)}" width="${barW}" height="${Math.max(bh, 1.5)}" rx="2" fill="${color}" data-tip="${tip}"/>`;
      s += `<text x="${bx + barW / 2}" y="${y(val) - 5}" text-anchor="middle" font-size="10" fill="var(--ink-2)">${val}</text>`;
    });
    s += `<text x="${cx}" y="${H - 10}" text-anchor="middle" font-size="11.5" fill="var(--muted)">${esc(p.planta.replace('Pta. ', ''))}</text>`;
  });
  s += '</svg>';
  $('mtp-c-blueprint').innerHTML = s;
}
function mtpRenderBlueprintTable() {
  const mi = mtpState.mes;
  const plants = MTP_DATA.filter(p => p.blueprint != null);
  $('mtp-bp-tbody').innerHTML = plants.map(p => {
    const real = p.real[mi] || 0, mtp = p.mtp[mi] || 0, bp = p.blueprint;
    const gap = real - bp;
    const cumpl = bp ? Math.round(real / bp * 100) : 0;
    return `<tr>
      <td>${esc(p.planta)}</td>
      <td class="num">${p.baseline}</td>
      <td class="num">${real}</td>
      <td class="num">${mtp}</td>
      <td class="num">${bp}</td>
      <td class="num"><span class="pill ${gap >= 0 ? 'pos' : 'neg'}">${gap > 0 ? '+' : ''}${gap}</span></td>
      <td class="num">${cumpl}%</td>
    </tr>`;
  }).join('');
}
function mtpRenderEstandar() {
  const mi = mtpState.mes;
  const items = MTP_DATA.map(p => {
    const gap = (p.real[mi] || 0) - (p.mtp[mi] || 0);
    return { label: p.planta, n: gap, tip: `<b>${esc(p.planta)}</b><br>MTP: <b>${p.mtp[mi] || 0}</b> · Real: <b>${p.real[mi] || 0}</b> · Dif: <b>${gap > 0 ? '+' : ''}${gap}</b>`, color: gap >= 0 ? 'var(--i)' : 'var(--neg)' };
  }).sort((a, b) => a.n - b.n);
  renderHBars($('mtp-c-estandar'), items);
}
function mtpRenderDist() {
  const mi = mtpState.mes;
  const items = MTP_DATA.map(p => ({ label: p.planta, n: p.real[mi] || 0, total: 0, color: 'var(--v)' }))
    .sort((a, b) => b.n - a.n);
  const totalReal = items.reduce((a, d) => a + d.n, 0);
  items.forEach(d => d.total = totalReal);
  renderBajasHBars($('mtp-c-dist'), items, 'del headcount total');
}
function mtpRenderTable() {
  const mi = mtpState.mes;
  const q = mtpState.q;
  const list = MTP_DATA.filter(p => !q || p.planta.toLowerCase().includes(q));
  $('mtp-tbody').innerHTML = list.map(p => {
    const real = p.real[mi] || 0, objetivo = mtpObjetivo(p, mi), gap = real - objetivo;
    const tipo = p.blueprint != null ? 'Blueprint*' : 'Estándar';
    return `<tr>
      <td>${esc(p.planta)}</td><td>${tipo}</td>
      <td class="num">${p.baseline}</td><td class="num">${real}</td><td class="num">${objetivo}</td>
      <td class="num"><span class="pill ${gap >= 0 ? 'pos' : 'neg'}">${gap > 0 ? '+' : ''}${gap}</span></td>
    </tr>`;
  }).join('');
  $('mtp-tempty').hidden = list.length > 0;
  $('mtp-tcount').textContent = `${list.length} de ${MTP_DATA.length} plantas`;
}
function mtpRenderFooter() {
  $('mtp-footer-text').textContent = `Elaborado a partir de la planilla de headcount (${MTP_DATA.length} plantas). El % de cumplimiento general (Bloque 1) compara Real vs. MTP para todas las plantas, sin usar Blueprint. Capdeville, Campana, Malagueño y Puesto Viejo (marcadas "Blueprint*" en la tabla) tienen además un valor Blueprint fijo asignado, comparado por separado en el Bloque 2 — esa comparación no modifica el % de cumplimiento general. La "Línea base" corresponde a la dotación al 31/12/2025.`;
}
function mtpInitFiltersAndRender() {
  const lastMi = MTP_MES_NOM.length - 1;
  mtpState.mes = lastMi; mtpState.q = '';

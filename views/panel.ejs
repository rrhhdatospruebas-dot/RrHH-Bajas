<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Panel de Personal — Holcim Argentina</title>
<style>
  /* ---------- barra de sesión ---------- */
  .sesion {
    display: flex; align-items: center; gap: 12px; justify-content: flex-end;
    font-size: 12.5px; color: var(--muted); margin-bottom: 10px;
  }
  .sesion a { color: var(--v); text-decoration: none; }
  .sesion a:hover { text-decoration: underline; }
  .sesion form { margin: 0; }
  .sesion button {
    font: inherit; font-size: 12.5px; color: var(--ink-2);
    background: none; border: 1px solid var(--border); border-radius: 8px;
    padding: 4px 10px; cursor: pointer;
  }
  .sesion button:hover { background: var(--hover-wash); }

  :root {
    --page: #f9f9f7;
    --surface: #fcfcfb;
    --ink: #0b0b0b;
    --ink-2: #52514e;
    --muted: #898781;
    --grid: #e1e0d9;
    --baseline: #c3c2b7;
    --border: rgba(11, 11, 11, 0.10);
    --v: #2a78d6;   /* serie Voluntaria / MTP */
    --i: #1baf7a;   /* serie Involuntaria / Real-cumplido */
    --neg: #c0392b;  /* gap negativo */
    --hover-wash: rgba(11, 11, 11, 0.04);
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --page: #0d0d0d; --surface: #1a1a19; --ink: #ffffff; --ink-2: #c3c2b7;
      --muted: #898781; --grid: #2c2c2a; --baseline: #383835;
      --border: rgba(255, 255, 255, 0.10);
      --v: #3987e5; --i: #199e70; --neg: #e0564a;
      --hover-wash: rgba(255, 255, 255, 0.05);
    }
  }
  :root[data-theme="dark"] {
    --page: #0d0d0d; --surface: #1a1a19; --ink: #ffffff; --ink-2: #c3c2b7;
    --muted: #898781; --grid: #2c2c2a; --baseline: #383835;
    --border: rgba(255, 255, 255, 0.10);
    --v: #3987e5; --i: #199e70; --neg: #e0564a;
    --hover-wash: rgba(255, 255, 255, 0.05);
  }
  :root[data-theme="light"] {
    --page: #f9f9f7; --surface: #fcfcfb; --ink: #0b0b0b; --ink-2: #52514e;
    --muted: #898781; --grid: #e1e0d9; --baseline: #c3c2b7;
    --border: rgba(11, 11, 11, 0.10);
    --v: #2a78d6; --i: #1baf7a; --neg: #c0392b;
    --hover-wash: rgba(11, 11, 11, 0.04);
  }

  * { box-sizing: border-box; }
  body {
    margin: 0; background: var(--page); color: var(--ink);
    font: 14px/1.45 system-ui, -apple-system, "Segoe UI", sans-serif;
  }
  .wrap { max-width: 1080px; margin: 0 auto; padding: 28px 20px 48px; }

  /* ---------- header global ---------- */
  header.top .eyebrow {
    font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--muted); margin-bottom: 6px;
  }
  header.top h1 { font-size: 24px; font-weight: 700; margin: 0 0 4px; text-wrap: balance; }
  header.top .sub { color: var(--ink-2); font-size: 13px; margin: 0; }

  /* ---------- tabs ---------- */
  .tabs { display: flex; gap: 22px; border-bottom: 1px solid var(--border); margin: 18px 0 22px; }
  .tab-btn {
    font: inherit; font-size: 13.5px; font-weight: 600; color: var(--muted);
    background: none; border: none; border-bottom: 2px solid transparent;
    padding: 10px 2px; margin-bottom: -1px; cursor: pointer;
  }
  .tab-btn:hover { color: var(--ink); }
  .tab-btn.active { color: var(--ink); border-bottom-color: var(--v); }

  /* ---------- section head (por vista) ---------- */
  .section-head h1 { font-size: 19px; font-weight: 700; margin: 0 0 4px; text-wrap: balance; }
  .section-head .sub { color: var(--ink-2); font-size: 13px; margin: 0 0 4px; }

  /* ---------- carga de excel ---------- */
  .upload-bar {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    margin: 14px 0 0; padding: 10px 12px;
    background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
  }
  .upload-btn {
    font: inherit; font-size: 12.5px; font-weight: 600; color: var(--ink);
    background: var(--page); border: 1px solid var(--border); border-radius: 8px;
    padding: 7px 12px; cursor: pointer; white-space: nowrap;
  }
  .upload-btn:hover { background: var(--hover-wash); }
  .file-input-hidden { position: absolute; width: 1px; height: 1px; overflow: hidden; opacity: 0; }
  .upload-status { font-size: 12px; color: var(--muted); }
  .upload-status.ok { color: var(--i); }
  .upload-status.err { color: var(--neg); }

  /* ---------- filtros ---------- */
  .filters { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin: 20px 0 18px; }
  .filters label { font-size: 12px; color: var(--ink-2); display: flex; align-items: center; gap: 6px; }
  .filters select {
    font: inherit; font-size: 13px; color: var(--ink);
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 6px 10px; min-width: 130px;
  }
  .filters select:focus-visible, .filters button:focus-visible, .search input:focus-visible {
    outline: 2px solid var(--v); outline-offset: 1px;
  }
  .filters button {
    font: inherit; font-size: 13px; color: var(--ink-2);
    background: none; border: 1px solid var(--border); border-radius: 8px;
    padding: 6px 12px; cursor: pointer; visibility: hidden;
  }
  .filters button.on { visibility: visible; }
  .filters button:hover { background: var(--hover-wash); }

  /* ---------- KPIs ---------- */
  .kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 12px; }
  @media (max-width: 780px) { .kpis { grid-template-columns: repeat(2, 1fr); } }
  .kpi { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 14px 16px; }
  .kpi .lbl { font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); }
  .kpi .val { font-size: 30px; font-weight: 700; line-height: 1.15; margin-top: 2px; }
  .kpi .val.pos { color: var(--i); } .kpi .val.neg { color: var(--neg); }
  .kpi .sub { font-size: 12px; color: var(--ink-2); margin-top: 2px; }

  /* ---------- tarjetas / grilla ---------- */
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 780px) { .grid { grid-template-columns: 1fr; } }
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 16px; min-width: 0; }
  .card.full { grid-column: 1 / -1; }
  .card h2 { font-size: 14px; font-weight: 650; margin: 0; }
  .card .hint { font-size: 12px; color: var(--muted); margin: 1px 0 12px; }
  .card-head { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; flex-wrap: wrap; }

  .legend { display: flex; flex-wrap: wrap; gap: 14px; font-size: 12px; color: var(--ink-2); }
  .legend span { display: inline-flex; align-items: center; gap: 6px; }
  .sw { width: 10px; height: 10px; border-radius: 3px; flex: none; }
  .sw.v { background: var(--v); } .sw.i { background: var(--i); } .sw.s { background: var(--muted); } .sw.n { background: var(--neg); }
  .sw.line { width: 14px; height: 3px; border-radius: 2px; }

  /* ---------- section-divider dentro de la pestaña MTP ---------- */
  .subsection-head { margin: 26px 0 12px; padding-top: 18px; border-top: 1px solid var(--border); }
  .subsection-head:first-of-type { margin-top: 0; padding-top: 0; border-top: none; }
  .subsection-head h3 { font-size: 15px; font-weight: 700; margin: 0 0 3px; }
  .subsection-head .hint { font-size: 12.5px; color: var(--ink-2); margin: 0; }

  /* ---------- chart mensual ---------- */
  .chart-mes svg { display: block; width: 100%; height: auto; }
  .chart-mes text { font-family: inherit; }

  /* ---------- barras horizontales ---------- */
  .hbars { display: flex; flex-direction: column; gap: 7px; }
  .hrow { display: grid; grid-template-columns: 138px 1fr 40px; align-items: center; gap: 8px; border-radius: 6px; padding: 2px 4px; }
  .hrow:hover { background: var(--hover-wash); }
  .hrow .hl { font-size: 12.5px; color: var(--ink-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .hrow .track { height: 14px; display: flex; align-items: center; min-width: 0; position: relative; background: var(--grid); border-radius: 2px 4px 4px 2px; }
  .hrow .bar { height: 14px; border-radius: 2px 4px 4px 2px; min-width: 2px; position: absolute; top: 0; }
  .hrow .hv { font-size: 12.5px; color: var(--ink); text-align: right; font-variant-numeric: tabular-nums; }

  /* ---------- tabla ---------- */
  .search { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; flex-wrap: wrap; }
  .search input {
    font: inherit; font-size: 13px; color: var(--ink);
    background: var(--page); border: 1px solid var(--border);
    border-radius: 8px; padding: 6px 10px; width: 260px; max-width: 100%;
  }
  .search .count { font-size: 12px; color: var(--muted); }
  .tblwrap { overflow: auto; max-height: 420px; border: 1px solid var(--border); border-radius: 8px; }
  table { border-collapse: collapse; width: 100%; font-size: 12.5px; }
  thead th {
    position: sticky; top: 0; background: var(--surface); z-index: 1;
    text-align: left; font-size: 11px; font-weight: 600; letter-spacing: 0.05em;
    text-transform: uppercase; color: var(--muted);
    padding: 8px 10px; border-bottom: 1px solid var(--grid); white-space: nowrap;
  }
  tbody td { padding: 7px 10px; border-bottom: 1px solid var(--grid); white-space: nowrap; color: var(--ink-2); }
  tbody td:first-child { color: var(--ink); font-weight: 500; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: var(--hover-wash); }
  td.num { font-variant-numeric: tabular-nums; }
  .pill { display: inline-block; font-size: 11px; font-weight: 600; padding: 1px 8px; border-radius: 99px; color: var(--ink); }
  .pill.V { background: color-mix(in srgb, var(--v) 18%, transparent); }
  .pill.I { background: color-mix(in srgb, var(--i) 22%, transparent); }
  .pill.S { background: color-mix(in srgb, var(--muted) 22%, transparent); }
  .pill.pos { background: color-mix(in srgb, var(--i) 20%, transparent); color: var(--i); }
  .pill.neg { background: color-mix(in srgb, var(--neg) 18%, transparent); color: var(--neg); }
  .empty { padding: 24px; text-align: center; color: var(--muted); }

  /* ---------- tooltip ---------- */
  #tip {
    position: fixed; pointer-events: none; z-index: 10; display: none;
    background: var(--ink); color: var(--page);
    font-size: 12px; line-height: 1.5; padding: 7px 10px; border-radius: 8px;
    max-width: 260px; box-shadow: 0 4px 14px rgba(0,0,0,0.25);
  }
  #tip b { font-variant-numeric: tabular-nums; }

  footer.bottom { margin-top: 20px; font-size: 12px; color: var(--muted); line-height: 1.6; }

  @media (prefers-reduced-motion: no-preference) {
    .hrow .bar { transition: width 0.25s ease, left 0.25s ease; }
  }
</style>
</head>
<body>

<div class="wrap">
  <div class="sesion">
    <span>Sesión de <strong><%= usuario %></strong></span>
    <% if (esAdmin) { %><a href="/admin">Administración</a><% } %>
    <form method="post" action="/logout"><button type="submit">Cerrar sesión</button></form>
  </div>
  <header class="top">
    <div class="eyebrow">Recursos Humanos · Argentina</div>
    <h1>Panel de Personal — Holcim Argentina</h1>
    <p class="sub">Bajas de personal y control de dotación (Real vs MTP). Elegí la pestaña y cargá el Excel correspondiente en cada una.</p>
  </header>

  <nav class="tabs" role="tablist" aria-label="Vistas">
    <button class="tab-btn active" id="tab-btn-bajas" type="button" role="tab" aria-selected="true">Bajas de personal</button>
    <button class="tab-btn" id="tab-btn-mtp" type="button" role="tab" aria-selected="false">Comparación Headcount vs MTP</button>
    <button class="tab-btn" id="tab-btn-altas" type="button" role="tab" aria-selected="false">Altas de personal</button>
  </nav>

  <!-- ============================================================ -->
  <!-- VISTA: BAJAS                                                  -->
  <!-- ============================================================ -->
  <section id="view-bajas">
    <div class="section-head">
      <h1 id="header-h1">Bajas de personal — Enero a Junio 2026</h1>
      <p class="sub">Desvinculaciones registradas por mes, motivo, sitio y dirección. Fuente: planilla de RRHH (Google Sheets).</p>
    </div>

    <div class="upload-bar">
      <% if (esAdmin) { %>
      <label class="upload-btn" for="file-input">📤 Cargar nuevo Excel (.xlsx)</label>
      <input type="file" class="file-input-hidden" id="file-input" accept=".xlsx,.xls" />
      <% } %>
      <span class="upload-status" id="upload-status">Datos iniciales cargados.</span>
    </div>

    <div class="filters" role="group" aria-label="Filtros de bajas">
      <label>Mes <select id="f-mes"><option value="">Todos</option></select></label>
      <label>Tipo
        <select id="f-tipo">
          <option value="">Todos</option>
          <option value="V">Voluntaria</option>
          <option value="I">Involuntaria</option>
          <option value="S">Sin definir</option>
        </select>
      </label>
      <label>Sitio <select id="f-sitio"><option value="">Todos</option></select></label>
      <button id="f-clear" type="button">Limpiar filtros</button>
    </div>

    <div class="kpis">
      <div class="kpi"><div class="lbl">Total bajas</div><div class="val" id="k-total">–</div><div class="sub" id="k-total-sub"></div></div>
      <div class="kpi"><div class="lbl">Voluntarias</div><div class="val" id="k-vol">–</div><div class="sub" id="k-vol-sub"></div></div>
      <div class="kpi"><div class="lbl">Involuntarias</div><div class="val" id="k-inv">–</div><div class="sub" id="k-inv-sub"></div></div>
      <div class="kpi"><div class="lbl">Mes pico</div><div class="val" id="k-pico">–</div><div class="sub" id="k-pico-sub"></div></div>
    </div>

    <div class="grid">
      <div class="card full">
        <div class="card-head">
          <div><h2>Bajas por mes</h2><div class="hint">Apiladas por tipo de baja</div></div>
          <div class="legend"><span><span class="sw v"></span>Voluntaria</span><span><span class="sw i"></span>Involuntaria</span><span><span class="sw s"></span>Sin definir</span></div>
        </div>
        <div class="chart-mes" id="c-mes"></div>
      </div>

      <div class="card">
        <div class="card-head"><div><h2>Por motivo</h2><div class="hint">Color según tipo de baja</div></div></div>
        <div class="hbars" id="c-motivo"></div>
      </div>

      <div class="card">
        <div class="card-head"><div><h2>Por sitio</h2><div class="hint">Planta / división de personal</div></div></div>
        <div class="hbars" id="c-sitio"></div>
      </div>

      <div class="card">
        <div class="card-head"><div><h2>Por dirección</h2><div class="hint">Estructura organizativa</div></div></div>
        <div class="hbars" id="c-dir"></div>
      </div>

      <div class="card">
        <div class="card-head"><div><h2>Género</h2><div class="hint">Distribución de las bajas</div></div></div>
        <div class="propbar" id="c-gen-bar" style="display:flex;height:22px;border-radius:6px;overflow:hidden;gap:2px;margin-bottom:10px;"></div>
        <div class="prop-legend" id="c-gen-leg" style="display:flex;flex-direction:column;gap:6px;font-size:13px;color:var(--ink-2);"></div>
      </div>

      <div class="card full">
        <div class="card-head"><div><h2>Detalle de bajas</h2><div class="hint">Todos los registros del período filtrado</div></div></div>
        <div class="search">
          <input id="q" type="search" placeholder="Buscar por nombre, sitio, gerencia…" aria-label="Buscar en la tabla">
          <span class="count" id="tcount"></span>
        </div>
        <div class="tblwrap">
          <table>
            <thead><tr><th>Empleado</th><th>Fecha</th><th>Tipo</th><th>Motivo</th><th>Sitio</th><th>Dirección</th><th>Gerencia</th><th>BP</th></tr></thead>
            <tbody id="tbody"></tbody>
          </table>
          <div class="empty" id="tempty" hidden>Sin resultados con los filtros actuales.</div>
        </div>
      </div>
    </div>

    <footer class="bottom">
      <span id="footer-text">Elaborado a partir de la planilla de bajas (70 registros, ene–jun 2026). Nota de calidad de datos: 4 registros tienen la columna DIRECCION vacía o mal cargada en la planilla y figuran como “Sin dato”.</span>
    </footer>
  </section>

  <!-- ============================================================ -->
  <!-- VISTA: COMPARACIÓN HEADCOUNT VS MTP                           -->
  <!-- ============================================================ -->
  <section id="view-mtp" hidden>
    <div class="section-head">
      <h1 id="mtp-h1">Headcount Real vs MTP — 2026</h1>
      <p class="sub">Comparación general: dotación real de <b>todas</b> las plantas vs. MTP y vs. línea base al 31/12/25. Las 4 plantas con Blueprint fijo (Capdeville, Campana, Malagueño, Puesto Viejo) se comparan además, en un bloque aparte, sin afectar el % de cumplimiento general.</p>
    </div>

    <div class="upload-bar">
      <% if (esAdmin) { %>
      <label class="upload-btn" for="mtp-file-input">📤 Cargar nuevo Excel (.xlsx)</label>
      <input type="file" class="file-input-hidden" id="mtp-file-input" accept=".xlsx,.xls" />
      <% } %>
      <span class="upload-status" id="mtp-upload-status">Datos iniciales cargados.</span>
    </div>

    <div class="filters" role="group" aria-label="Filtros de headcount">
      <label>Mes <select id="mtp-f-mes"></select></label>
    </div>

    <!-- ---------- BLOQUE 1: TODAS LAS PLANTAS (vs. MTP y línea base) ---------- -->
    <div class="subsection-head">
      <h3>1. Todas las plantas — Real vs. MTP y vs. Línea base 31/12/25</h3>
      <p class="hint">Base del % de cumplimiento general. No incluye Blueprint.</p>
    </div>

    <div class="kpis">
      <div class="kpi"><div class="lbl">Headcount Real</div><div class="val" id="mtp-k-real">–</div><div class="sub" id="mtp-k-real-sub"></div></div>
      <div class="kpi"><div class="lbl">vs. Línea base 31/12/25</div><div class="val" id="mtp-k-base">–</div><div class="sub" id="mtp-k-base-sub"></div></div>
      <div class="kpi"><div class="lbl">vs. Objetivo (MTP)</div><div class="val" id="mtp-k-gap">–</div><div class="sub" id="mtp-k-gap-sub"></div></div>
      <div class="kpi"><div class="lbl">% Cumplimiento</div><div class="val" id="mtp-k-pct">–</div><div class="sub" id="mtp-k-pct-sub"></div></div>
    </div>

    <div class="grid">
      <div class="card full">
        <div class="card-head">
          <div><h2>Evolución temporal del headcount</h2><div class="hint">Total compañía (todas las plantas) — Real vs. MTP vs. Línea base 31/12/25, enero a junio</div></div>
          <div class="legend"><span><span class="sw line" style="background:var(--i)"></span>Real</span><span><span class="sw line" style="background:var(--v)"></span>MTP</span><span><span class="sw line" style="background:var(--muted); border-top:2px dashed var(--muted); height:0;"></span>Línea base 31/12/25</span></div>
        </div>
        <div class="chart-mes" id="mtp-c-trend"></div>
      </div>

      <div class="card">
        <div class="card-head"><div><h2>Todas las plantas</h2><div class="hint">Real − MTP del mes seleccionado</div></div></div>
        <div class="hbars" id="mtp-c-estandar"></div>
      </div>

      <div class="card">
        <div class="card-head"><div><h2>Distribución de headcount</h2><div class="hint">Todas las plantas, real del mes seleccionado, de mayor a menor</div></div></div>
        <div class="hbars" id="mtp-c-dist"></div>
      </div>

      <div class="card full">
        <div class="card-head"><div><h2>Detalle por planta</h2><div class="hint">Línea base, real, MTP y diferencia — mes seleccionado (todas las plantas)</div></div></div>
        <div class="search">
          <input id="mtp-q" type="search" placeholder="Buscar por planta…" aria-label="Buscar en la tabla de headcount">
          <span class="count" id="mtp-tcount"></span>
        </div>
        <div class="tblwrap">
          <table>
            <thead><tr><th>Planta</th><th>Tipo</th><th>Línea base 31/12/25</th><th>Real</th><th>MTP</th><th>Diferencia</th></tr></thead>
            <tbody id="mtp-tbody"></tbody>
          </table>
          <div class="empty" id="mtp-tempty" hidden>Sin resultados con los filtros actuales.</div>
        </div>
      </div>
    </div>

    <!-- ---------- BLOQUE 2: PLANTAS BLUEPRINT (comparación adicional) ---------- -->
    <div class="subsection-head">
      <h3>2. Plantas Blueprint — Capdeville, Campana, Malagueño y Puesto Viejo</h3>
      <p class="hint">Comparación adicional (Real, Línea base, MTP y Blueprint juntos). No modifica el % de cumplimiento general del Bloque 1.</p>
    </div>

    <div class="grid">
      <div class="card full">
        <div class="card-head">
          <div><h2>Matriz de brecha Blueprint</h2><div class="hint">Capdeville, Campana, Malagueño y Puesto Viejo — Real | Blueprint | MTP del mes seleccionado</div></div>
          <div class="legend">
            <span><span class="sw" style="background:var(--i);border-radius:3px;"></span>Real</span>
            <span><span class="sw" style="background:#c0392b;border-radius:3px;"></span>Blueprint</span>
            <span><span class="sw" style="background:var(--v);border-radius:3px;"></span>MTP</span>
          </div>
        </div>
        <div class="chart-mes" id="mtp-c-blueprint"></div>
      </div>

      <div class="card full">
        <div class="card-head"><div><h2>Detalle Blueprint</h2><div class="hint">Línea base, Real, MTP y Blueprint — mes seleccionado</div></div></div>
        <div class="tblwrap">
          <table>

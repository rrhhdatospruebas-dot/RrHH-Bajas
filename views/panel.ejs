async function mtpParseExcelFile(file) {
  const buf = await file.arrayBuffer();
  const wb = XLSX.read(buf, { type: 'array', cellDates: true });
  const sheetName = wb.SheetNames.find(n => n.trim().toLowerCase() === 'sheet5') || wb.SheetNames[0];
  const ws = wb.Sheets[sheetName];
  const rows = XLSX.utils.sheet_to_json(ws, { header: 1, raw: true, defval: null });
  if (!rows.length) throw new Error('La hoja está vacía.');
  const out = [];
  for (let r = 1; r < rows.length; r++) {
    const row = rows[r];
    if (!row || row[0] == null || String(row[0]).trim() === '') continue;
    const nameRaw = String(row[0]).trim();
    const label = MTP_PLANT_LABELS[nameRaw.toUpperCase()] || nameRaw;
    let baseline = 0, blueprint = null;
    const real = [], mtp = [];
    for (let mi = 0; mi < 6; mi++) {
      const base = 1 + mi * 4;
      const b = row[base], re_ = row[base + 1], m = row[base + 2], bp = row[base + 3];
      if (typeof b === 'number') baseline = b;
      real.push(typeof re_ === 'number' ? re_ : 0);
      mtp.push(typeof m === 'number' ? m : 0);
      if (typeof bp === 'number') blueprint = bp;
    }
    out.push({ planta: label, baseline, real, mtp, blueprint });
  }
  if (!out.length) throw new Error('No se encontraron filas de plantas válidas en la hoja.');
  return out;
}
async function mtpInit() {
  try {
    const stored = await window.storage.get('mtp-dataset', true);
    if (stored && stored.value) {
      const parsed = JSON.parse(stored.value);
      if (parsed && Array.isArray(parsed.records) && parsed.records.length) {
        MTP_DATA = parsed.records;
        const fecha = parsed.uploadedAt ? new Date(parsed.uploadedAt).toLocaleString('es-AR') : '';
        $('mtp-upload-status').textContent = `Últimos datos cargados: "${parsed.filename || 'archivo'}"${fecha ? ' · ' + fecha : ''}`;
        $('mtp-upload-status').className = 'upload-status ok';
      }
    }
  } catch (err) {}
  mtpInitFiltersAndRender();
}
onChange('mtp-file-input', async (e) => {
  const file = e.target.files[0];
  if (!file) return;
  const statusEl = $('mtp-upload-status');
  statusEl.textContent = 'Procesando archivo…'; statusEl.className = 'upload-status';
  try {
    const records = await mtpParseExcelFile(file);
    MTP_DATA = records;
    const uploadedAt = new Date().toISOString();
    try { await window.storage.set('mtp-dataset', JSON.stringify({ records, uploadedAt, filename: file.name }), true); }
    catch (err) { throw new Error(`El archivo se procesó pero NO se guardó en el servidor (${err.message}). Los demás usuarios no van a ver este cambio: probá de nuevo.`); }
    mtpInitFiltersAndRender();
    statusEl.textContent = `✓ ${records.length} plantas cargadas desde "${file.name}".`;
    statusEl.className = 'upload-status ok';
  } catch (err) { statusEl.textContent = '⚠ ' + err.message; statusEl.className = 'upload-status err'; }
  e.target.value = '';
});


/* ================= filtros ================= */
['f-mes', 'f-tipo', 'f-sitio'].forEach(id => $(id).addEventListener('change', () => {
  state.mes = $('f-mes').value; state.tipo = $('f-tipo').value; state.sitio = $('f-sitio').value;
  render();
}));
$('f-clear').addEventListener('click', () => {
  state.mes = state.tipo = state.sitio = '';
  $('f-mes').value = $('f-tipo').value = $('f-sitio').value = '';
  render();
});
$('q').addEventListener('input', e => { state.q = e.target.value.trim().toLowerCase(); renderTable(filtered()); });

function filtered() {
  return DATA.filter(r =>
    (!state.mes || kMes(r) === state.mes) &&
    (!state.tipo || r.t === state.tipo) &&
    (!state.sitio || r.s === state.sitio));
}

function countBy(arr, key) {
  const m = new Map();
  arr.forEach(r => { const k = key(r); m.set(k, (m.get(k) || 0) + 1); });
  return m;
}

/* ================= KPIs ================= */
function renderKPIs(rows) {
  const total = rows.length;
  const v = rows.filter(r => r.t === 'V').length;
  const i = total - v;
  $('k-total').textContent = total;
  $('k-total-sub').textContent = total === DATA.length ? periodoLabel() : `de ${DATA.length} en el período`;
  $('k-vol').textContent = v;
  $('k-vol-sub').textContent = pct(v, total) + ' del total';
  $('k-inv').textContent = i;
  $('k-inv-sub').textContent = pct(i, total) + ' del total';
  const porMes = countBy(rows, kMes);
  let pico = null;
  porMes.forEach((n, m) => { if (!pico || n > pico[1]) pico = [m, n]; });
  $('k-pico').textContent = pico ? mesNom(pico[0]) : '–';
  $('k-pico-sub').textContent = pico ? `${pico[1]} bajas` : '';
}

/* ================= gráfico mensual ================= */
function renderMes(rows) {
  const W = 680, H = 250, mL = 30, mR = 8, mT = 26, mB = 24;
  const iw = W - mL - mR, ih = H - mT - mB;
  const perMes = MESES.map(k => {
    const v = rows.filter(r => kMes(r) === k && r.t === 'V').length;
    const i = rows.filter(r => kMes(r) === k && r.t === 'I').length;
    return { k, v, i, tot: v + i };
  });
  const maxTot = Math.max(...perMes.map(d => d.tot), 1);
  const yMax = Math.max(5, Math.ceil(maxTot / 5) * 5);
  const y = val => mT + ih - (val / yMax) * ih;
  const step = iw / Math.max(MESES.length, 1);
  const bw = Math.min(52, step * 0.5);
  const GAP = 2;
  const tickStep = yMax > 30 ? 10 : 5;

  let s = `<svg viewBox="0 0 ${W} ${H}" role="img" aria-label="Bajas por mes, apiladas por tipo">`;
  for (let t = 0; t <= yMax; t += tickStep) {
    s += `<line x1="${mL}" x2="${W - mR}" y1="${y(t)}" y2="${y(t)}" stroke="${t === 0 ? 'var(--baseline)' : 'var(--grid)'}" stroke-width="1"/>`;
    s += `<text x="${mL - 6}" y="${y(t) + 4}" text-anchor="end" font-size="11" fill="var(--muted)">${t}</text>`;
  }
  perMes.forEach((d, idx) => {
    const cx = mL + step * idx + step / 2;
    const x = cx - bw / 2;
    const hV = (d.v / yMax) * ih;
    const hI = (d.i / yMax) * ih;
    const yV = y(d.v);
    const r = 4;
    if (d.i > 0) {
      const yI = yV - GAP - hI;
      s += roundedTop(x, yI, bw, Math.max(hI, 1.5), r, 'var(--i)');
      if (d.v > 0) s += `<rect x="${x}" y="${yV}" width="${bw}" height="${Math.max(hV, 1.5)}" fill="var(--v)"/>`;
    } else if (d.v > 0) {
      s += roundedTop(x, yV, bw, Math.max(hV, 1.5), r, 'var(--v)');
    }
    if (d.tot > 0) s += `<text x="${cx}" y="${(d.i > 0 ? yV - GAP - hI : yV) - 6}" text-anchor="middle" font-size="12" fill="var(--ink-2)">${d.tot}</text>`;
    s += `<text x="${cx}" y="${H - 6}" text-anchor="middle" font-size="11.5" fill="var(--muted)">${mesAbr(d.k)}</text>`;
    s += `<rect x="${mL + step * idx}" y="${mT}" width="${step}" height="${ih}" fill="transparent" data-tip="${esc(`<b>${mesNom(d.k)}</b> — ${d.tot} baja${d.tot === 1 ? '' : 's'}<br>Voluntarias: <b>${d.v}</b> · Involuntarias: <b>${d.i}</b>`)}"/>`;
  });
  s += '</svg>';
  $('c-mes').innerHTML = s;
}
function roundedTop(x, yy, w, h, r, fill) {
  r = Math.min(r, h, w / 2);
  return `<path d="M${x},${yy + h} L${x},${yy + r} Q${x},${yy} ${x + r},${yy} L${x + w - r},${yy} Q${x + w},${yy} ${x + w},${yy + r} L${x + w},${yy + h} Z" fill="${fill}"/>`;
}

/* ================= barras horizontales ================= */
function renderHBars(el, items, tipLabel) {
  const max = Math.max(...items.map(d => d.n), 1);
  el.innerHTML = items.map(d => `
    <div class="hrow" data-tip="${esc(`<b>${d.label}</b><br>${d.n} baja${d.n === 1 ? '' : 's'} · ${pct(d.n, d.total)} ${tipLabel}`)}">
      <span class="hl" title="${esc(d.label)}">${esc(d.label)}</span>
      <span class="track"><span class="bar" style="width:${(d.n / max * 100).toFixed(1)}%; background:${d.color}"></span></span>
      <span class="hv">${d.n}</span>
    </div>`).join('');
}

function renderMotivo(rows) {
  const m = new Map();
  rows.forEach(r => { const k = r.m + '|' + r.t; m.set(k, (m.get(k) || 0) + 1); });
  const items = [...m.entries()].map(([k, n]) => {
    const [label, t] = k.split('|');
    return { label: label + (label === 'Fin de contrato' ? (t === 'V' ? ' (vol.)' : ' (invol.)') : ''), n, total: rows.length, color: t === 'V' ? 'var(--v)' : 'var(--i)' };
  }).sort((a, b) => b.n - a.n);
  renderHBars($('c-motivo'), items, 'del total filtrado');
}

function renderDim(el, rows, key) {
  const items = [...countBy(rows, key).entries()]
    .map(([label, n]) => ({ label, n, total: rows.length, color: 'var(--v)' }))
    .sort((a, b) => b.n - a.n);
  renderHBars(el, items, 'del total filtrado');
}

/* ================= género ================= */
function renderGenero(rows) {
  const m = rows.filter(r => r.g === 'M').length;
  const f = rows.length - m;
  const bar = $('c-gen-bar'), leg = $('c-gen-leg');
  if (!rows.length) { bar.innerHTML = ''; leg.innerHTML = '<span class="row">Sin datos para los filtros actuales.</span>'; return; }
  bar.innerHTML =
    (m ? `<div style="flex:${m}; background:var(--v)" data-tip="<b>Masculino</b>: ${m} (${pct(m, rows.length)})"></div>` : '') +
    (f ? `<div style="flex:${f}; background:var(--i)" data-tip="<b>Femenino</b>: ${f} (${pct(f, rows.length)})"></div>` : '');
  leg.innerHTML = `
    <span class="row"><span class="sw v"></span>Masculino&nbsp;<b>${m}</b>&nbsp;· ${pct(m, rows.length)}</span>
    <span class="row"><span class="sw i"></span>Femenino&nbsp;<b>${f}</b>&nbsp;· ${pct(f, rows.length)}</span>`;
}

/* ================= tabla ================= */
function renderTable(rows) {
  const q = state.q;
  const list = rows
    .filter(r => !q || [r.n, r.s, r.dir, r.ger, r.bp, r.m].join(' ').toLowerCase().includes(q))
    .sort((a, b) => a.f.localeCompare(b.f));
  $('tbody').innerHTML = list.map(r => {
    const [y, mo, d] = r.f.split('-');
    return `<tr>
      <td>${esc(r.n)}</td>
      <td class="num">${d}/${mo}/${y}</td>
      <td><span class="pill ${r.t}">${r.t === 'V' ? 'Voluntaria' : 'Involuntaria'}</span></td>
      <td>${esc(r.m)}</td>
      <td>${esc(r.s)}</td>
      <td>${esc(r.dir)}</td>
      <td>${esc(r.ger)}</td>
      <td>${esc(r.bp)}</td>
    </tr>`;
  }).join('');
  $('tempty').hidden = list.length > 0;
  $('tcount').textContent = `${list.length} de ${DATA.length} registros`;
}

/* ================= tooltip ================= */
const tip = $('tip');
document.addEventListener('mouseover', e => {
  const t = e.target.closest('[data-tip]');
  if (t) { tip.innerHTML = t.dataset.tip; tip.style.display = 'block'; }
  else tip.style.display = 'none';
});
document.addEventListener('mousemove', e => {
  if (tip.style.display !== 'block') return;
  const pad = 14;
  let x = e.clientX + pad, yy = e.clientY + pad;
  const r = tip.getBoundingClientRect();
  if (x + r.width > innerWidth - 8) x = e.clientX - r.width - pad;
  if (yy + r.height > innerHeight - 8) yy = e.clientY - r.height - pad;
  tip.style.left = x + 'px'; tip.style.top = yy + 'px';
});

/* ================= render maestro ================= */
function render() {
  const rows = filtered();
  $('f-clear').classList.toggle('on', !!(state.mes || state.tipo || state.sitio));
  renderKPIs(rows);
  renderMes(rows);
  renderMotivo(rows);
  renderDim($('c-sitio'), rows, r => r.s);
  renderDim($('c-dir'), rows, r => r.dir);
  renderGenero(rows);
  renderTable(rows);
}
</script>
</body>
</html>

function parseCSV(text) {
  const rows = []; let row = [], cur = '', inQ = false;
  for (let i = 0; i < text.length; i++) {
    const c = text[i];
    if (inQ) {
      if (c === '"') { if (text[i + 1] === '"') { cur += '"'; i++; } else inQ = false; }
      else cur += c;
    } else {
      if (c === '"') inQ = true;
      else if (c === ',') { row.push(cur); cur = ''; }
      else if (c === '\n') { row.push(cur.replace(/\r$/, '')); rows.push(row); row = []; cur = ''; }
      else cur += c;
    }
  }
  if (cur.length || row.length) { row.push(cur.replace(/\r$/, '')); rows.push(row); }
  return rows;
}

function titleDir(d) {
  d = (d || '').trim();
  if (!d || !d.toUpperCase().includes('DIRECCI')) return 'Sin dato';
  return d.replace('DIRECCION', 'DIRECCIÓN').toLowerCase()
    .split(' ').map((w, i) => i === 0 ? 'Dirección' : (w === 'de' || w === 'y') ? w : w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ').replace(/Administracion/g, 'Administración');
}

function toRecords(csvText) {
  const rows = parseCSV(csvText);
  const out = [];
  for (let i = 1; i < rows.length; i++) {
    const r = rows[i];
    if (r.length < 13 || !r[0]) continue;
    const [cod, nombre, genero, motivoRaw, ceco, div, fecha, mesTxt, dir, director, ger, gerente, bp] = r;
    const mm = MOTIVO_MAP[motivoRaw.trim()];
    if (!mm || !fecha.includes('/')) continue;
    const [m, d, y] = fecha.split('/').map(Number);
    const gerT = (ger || '').trim();
    out.push({
      n: nombre, g: genero === 'Masculino' ? 'M' : 'F',
      t: mm[0], m: mm[1],
      s: SITE_MAP[div.trim()] || div.trim(),
      f: `${y}-${String(m).padStart(2, '0')}-${String(d).padStart(2, '0')}`,
      dir: titleDir(dir),
      ger: gerT ? (gerT.charAt(0) + gerT.slice(1).toLowerCase()).replace(/gerencia/i, 'Gcia.') : 'Sin dato',
      bp: (bp || '').trim() || 'Sin dato'
    });
  }
  return out;
}

/* ================= estado ================= */
const MES_ABR = ['', 'Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
const MES_NOM = ['', 'Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
let DATA = [];
let MESES = [];       // claves "AAAA-MM" ordenadas
let multiYear = false;
const state = { mes: '', tipo: '', sitio: '', q: '' };

const $ = id => document.getElementById(id);
const esc = s => String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
const pct = (n, d) => d ? Math.round(n / d * 100) + '%' : '–';
const kMes = r => r.f.slice(0, 7);
const mesNom = k => MES_NOM[+k.slice(5, 7)] + (multiYear ? ' ' + k.slice(0, 4) : '');
const mesAbr = k => MES_ABR[+k.slice(5, 7)] + (multiYear ? '’' + k.slice(2, 4) : '');

function periodoLabel() {
  if (!MESES.length) return 'sin datos';
  const a = MESES[0], b = MESES[MESES.length - 1];
  if (a === b) return `${MES_NOM[+a.slice(5, 7)]} ${a.slice(0, 4)}`;
  if (a.slice(0, 4) === b.slice(0, 4))
    return `${MES_NOM[+a.slice(5, 7)]} a ${MES_NOM[+b.slice(5, 7)]} ${a.slice(0, 4)}`;
  return `${MES_NOM[+a.slice(5, 7)]} ${a.slice(0, 4)} a ${MES_NOM[+b.slice(5, 7)]} ${b.slice(0, 4)}`;
}

/* ================= carga de datos ================= */
function setData(records, fuente) {
  DATA = records;
  MESES = [...new Set(DATA.map(kMes))].sort();
  multiYear = new Set(MESES.map(k => k.slice(0, 4))).size > 1;

  $('periodo').textContent = periodoLabel();
  document.title = `Bajas de Personal — ${periodoLabel()}`;

  const selMes = $('f-mes'), selSitio = $('f-sitio');
  selMes.innerHTML = '<option value="">Todos</option>' +
    MESES.map(k => `<option value="${k}">${mesNom(k)}</option>`).join('');
  selSitio.innerHTML = '<option value="">Todos</option>' +
    [...new Set(DATA.map(r => r.s))].sort((a, b) => a.localeCompare(b, 'es'))
      .map(s => `<option value="${esc(s)}">${esc(s)}</option>`).join('');
  state.mes = state.sitio = '';

  const st = $('status');
  st.classList.remove('live', 'off');
  if (fuente === 'live') {
    st.classList.add('live');
    $('status-txt').textContent = `Datos en vivo del Google Sheet · leídos el ${new Date().toLocaleDateString('es-AR')} a las ${new Date().toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' })}`;
  } else {
    st.classList.add('off');
    $('status-txt').textContent = `Sin conexión al Sheet — mostrando copia guardada del ${SNAPSHOT_FECHA}`;
  }

  const sinDir = DATA.filter(r => r.dir === 'Sin dato').length;
  $('foot').textContent =
    `Elaborado a partir de la planilla de bajas (${DATA.length} registros, ${periodoLabel().toLowerCase()}). ` +
    `Los datos se leen del Google Sheet cada vez que se abre o recarga esta página.` +
    (sinDir ? ` Nota de calidad de datos: ${sinDir} registro${sinDir === 1 ? ' tiene' : 's tienen'} la columna DIRECCION vacía o mal cargada en la planilla y figura${sinDir === 1 ? '' : 'n'} como “Sin dato”.` : '');

  render();
}

function init() {
  fetch(CSV_URL, { cache: 'no-store' })
    .then(r => { if (!r.ok) throw new Error(r.status); return r.text(); })
    .then(txt => {
      const recs = toRecords(txt);
      if (!recs.length) throw new Error('sin registros');
      setData(recs, 'live');
    })
    .catch(() => setData(SNAPSHOT, 'snapshot'));
}


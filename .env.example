# Copiá este archivo a .env y completá los valores reales

# Conexión a Neon Postgres (string completo con sslmode=require)
DATABASE_URL=postgresql://usuario:password@host/neondb?sslmode=require

# Secreto para firmar la cookie de sesión (cualquier string largo y aleatorio)
SESSION_SECRET=cambiar-por-un-string-largo-aleatorio

# Usuario administrador inicial (se crea solo si la tabla de usuarios está vacía)
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar-esta-clave

# Hoja de Google Sheets por defecto (después se gestiona desde /admin)
SHEET_ID=

# (Opcional) URL pública a mostrar en /admin. Si no se define, se usa el
# dominio de producción de Vercel o el host de la request.
# PUBLIC_URL=https://tu-proyecto.vercel.app

# Puerto local
PORT=3000
